DOTENV_PUBLIC_KEY="029e266f0a5d7d76c8ded843032fee719ad5f9a0d69f38d27c3752b6f837cdd090"

# .env
# ── Local development (dotenvx-encrypted) ────────────────────────────────────
# Decrypted with DOTENV_PRIVATE_KEY (see .env.keys, gitignored).
# Only the database URL differs from production; everything else is identical
# across environments.

# Local Neon DEV branch. Intentionally NOT the production database, so local
# work can't touch prod. Set both (DATABASE_URL is read by drizzle-kit,
# NUXT_DATABASE_URL by Nuxt runtimeConfig):
#   dotenvx set DATABASE_URL "<dev-branch-url>" -f .env
#   dotenvx set NUXT_DATABASE_URL "<dev-branch-url>" -f .env
DATABASE_URL=encrypted:

NUXT_DATABASE_URL=encrypted:

