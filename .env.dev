# .env.dev
# ── Netlify deploy-preview / branch-deploy (dotenvx-encrypted) ───────────────
# Decrypted at build time with DOTENV_PRIVATE_KEY_DEV (set in Netlify, Builds
# scope). Use a NON-production Neon branch so previews can't touch prod data.

# Preview Neon branch. Set with your preview/dev-branch URL:
#   dotenvx set DATABASE_URL "<preview-branch-url>" -f .env.dev
#   dotenvx set NUXT_DATABASE_URL "<preview-branch-url>" -f .env.dev
DATABASE_URL=encrypted:

NUXT_DATABASE_URL=encrypted:

