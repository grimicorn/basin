#/-------------------[DOTENV_PUBLIC_KEY]--------------------/
#/            public-key encryption for .env files          /
#/       [how it works](https://dotenvx.com/encryption)     /
#/----------------------------------------------------------/
DOTENV_PUBLIC_KEY_E2E="0353a151fced32457466fbb2889766fa1eeaa5d641041d75b18c927f2df8b03ebd"

# .env.e2e
# ── End-to-end tests (dotenvx-encrypted) ─────────────────────────────────────
# Decrypted with DOTENV_PRIVATE_KEY_E2E. Self-contained so CI needs only that
# one key (plus NEON_API_KEY / NEON_PROJECT_ID for per-run branch creation).
#
# Local: E2E_DATABASE_URL points at the dedicated Neon e2e branch below.
# CI:    the workflow creates a fresh per-run Neon branch and injects
#        E2E_DATABASE_URL, which overrides the value here (a value already in
#        the environment wins over the encrypted file in dotenvx).
E2E_DATABASE_URL=encrypted:

# Clerk — drives @clerk/testing during e2e
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=encrypted:BGkHt0/VCQx3/loJ5eLfl72tA4WNAWUbGaHC5GxdmM31/yp376dSj3YDJQtK6KI9CcyycFz6INZ3r0W4A17Cx6wKfMTCL8m6Q9BLGE1HNog1zEjv1iyRa2eKL9FMBIh4rqfvs6MQfsfueVt/3PUNzhJyN05GmdZKwyb696eTnUA0pHLhribv8bUNWrh6x0yVQAnHbodYuA==
