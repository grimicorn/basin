# ─────────────────────────────────────────────────────────────────────────────
# Reference of every variable the app reads. Real values are NOT kept here —
# they live ENCRYPTED in the committed dotenvx files:
#   .env             local dev          (key: DOTENV_PRIVATE_KEY)
#   .env.dev         Netlify previews   (key: DOTENV_PRIVATE_KEY_DEV)
#   .env.e2e         e2e tests / CI     (key: DOTENV_PRIVATE_KEY_E2E)
#   .env.production  Netlify production (key: DOTENV_PRIVATE_KEY_PRODUCTION)
#
# Change a value:  dotenvx set VAR "value" -f .env[.dev|.e2e|.production]
# Read decrypted:  dotenvx get -f .env
# Private keys live in .env.keys (gitignored). Back it up to your password
# manager — without it the encrypted files cannot be decrypted.
# Only the database URL differs per environment; everything else is identical.
# ─────────────────────────────────────────────────────────────────────────────

# Neon DB connection string
# Used by drizzle-kit CLI (db:generate, db:migrate, db:push, db:studio)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Same value — Nuxt reads this and maps it to runtimeConfig.databaseUrl
NUXT_DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Clerk — https://dashboard.clerk.com → API Keys
NUXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NUXT_CLERK_SECRET_KEY=sk_test_...

# Google OAuth — https://console.cloud.google.com → APIs & Services → Credentials
# Enable YouTube Data API v3; add /api/auth/youtube/callback as an authorized redirect URI
NUXT_GOOGLE_CLIENT_ID=
NUXT_GOOGLE_CLIENT_SECRET=

# Feed discovery SSRF allowlist (optional, for local dev / e2e only)
# Comma-separated list of host:port strings that bypass SSRF validation.
# Example: 127.0.0.1:3099 allows the local e2e mock server.
# NEVER set this in production.
NUXT_FEED_DISCOVERY_ALLOWED_HOSTS=

# Netlify Async Workloads — https://app.netlify.com → Project config → Build & Deploy → Async Workloads
# Required for the AsyncWorkloadsClient to authenticate when sending events.
# Generated automatically when you enable the Async Workloads extension; also available
# under Project configuration > Build & Deploy > Async Workloads → Create a new API key.
AWL_API_KEY=

# Sentry — https://sentry.io → Settings → Projects → <project> → Client Keys (DSN)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Sentry source map uploads — https://sentry.io → Settings → Auth Tokens
# Token needs the `project:releases` scope
# SENTRY_ORG is your organization slug (visible in the Sentry URL: sentry.io/organizations/<slug>/)
# SENTRY_PROJECT is your project slug (visible under Settings → Projects → <project>)
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
