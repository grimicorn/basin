{
  "name": "reader",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "TMPDIR=/tmp nuxt dev",
    "build": "nuxt build",
    "preview": "nuxt preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run",
    "lint": "prettier --check . && eslint . && fallow audit",
    "lint:ci": "prettier --check . && eslint . && fallow audit --base main",
    "lint:fix": "prettier --write . && eslint . --fix && fallow fix",
    "prepare": "husky"
  },
  "dependencies": {
    "nuxt": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "vitest": "^4.1.5",
    "@tailwindcss/vite": "^4.3.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/ui": "^4.1.5",
    "typescript": "^6.0.0",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "fallow": "^2.86.0",
    "globals": "^17.0.0",
    "happy-dom": "^20.0.0",
    "husky": "^9.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0"
  }
}
