{
  "name": "reader",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "TMPDIR=/tmp dotenvx run -f .env -- nuxt dev",
    "dev:test": "TMPDIR=/tmp nuxt dev",
    "build": "dotenvx run -f .env.production -- nuxt build",
    "build:dev": "dotenvx run -f .env.dev -- nuxt build",
    "preview": "dotenvx run -f .env.production -- nuxt preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run",
    "lint": "prettier --check . && eslint . && fallow audit",
    "lint:ci": "prettier --check . && eslint . && fallow audit --base origin/${BASE_BRANCH:-main}",
    "lint:fix": "prettier --write . && eslint . --fix && fallow fix",
    "prepare": "husky",
    "db:generate": "dotenvx run -f .env -- drizzle-kit generate",
    "db:migrate": "dotenvx run -f .env -- drizzle-kit migrate",
    "db:migrate:production": "dotenvx run -f .env.production -- drizzle-kit migrate",
    "db:push": "dotenvx run -f .env -- drizzle-kit push",
    "db:studio": "dotenvx run -f .env -- drizzle-kit studio",
    "e2e": "dotenvx run -f .env.e2e -- playwright test",
    "e2e:headed": "dotenvx run -f .env.e2e -- playwright test --headed",
    "e2e:ui": "dotenvx run -f .env.e2e -- playwright test --ui",
    "e2e:debug": "dotenvx run -f .env.e2e -- playwright test --debug",
    "e2e:report": "playwright show-report e2e/report"
  },
  "dependencies": {
    "@atproto/api": "^0.20.28",
    "@clerk/nuxt": "^2.6.16",
    "@dotenvx/dotenvx": "^2.4.1",
    "@electric-sql/pglite": "^0.5.4",
    "@neondatabase/serverless": "^1.1.0",
    "@netlify/async-workloads": "^0.0.106",
    "@netlify/functions": "^5.3.0",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.65.0",
    "drizzle-orm": "^0.45.2",
    "nuxt": "^4.4.8",
    "pinia": "^3.0.4",
    "rss-parser": "^3.13.0",
    "stripe": "^22.3.1"
  },
  "overrides": {
    "@netlify/sdk": "^5.0.4",
    "tmp": "^0.2.6",
    "http-proxy-middleware": "^4.1.1"
  },
  "devDependencies": {
    "@clerk/backend": "^3.5.0",
    "@clerk/testing": "^2.2.7",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "fallow": "^3.3.0",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.0.0",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  }
}
