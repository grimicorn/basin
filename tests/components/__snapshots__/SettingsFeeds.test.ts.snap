exports[`SettingsFeeds > shows empty state when there are no feeds 1`] = `
"<section class="set-section">
  <h2>RSS &amp; Podcasts</h2>
  <p class="desc"> Paste a feed URL or a plain website address — Reader will find the feed automatically. </p>
  <div class="add-feed">
    <input-text-stub modelvalue="" placeholder="https://example.com or https://example.com/feed.xml" disabled="false"></input-text-stub><button class="btn btn-primary">
      <r-icon-stub name="plus" size="16"></r-icon-stub> Add feed
    </button>
  </div>
  <!--v-if-->
  <div class="feed-list">
    <p class="desc">No feeds added yet.</p>
  </div>
</section>"
`;
